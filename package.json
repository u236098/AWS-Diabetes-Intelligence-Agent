{
  "name": "diabetes-intelligence-agent",
  "version": "1.0.0",
  "description": "Production-ready Diabetes Intelligence Agent on AWS using CDK",
  "author": "AWS Prompt the Planet Challenge Submission",
  "license": "MIT",
  "bin": {
    "diabetes-intelligence-agent": "bin/app.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "deploy": "cdk deploy --all --require-approval never",
    "deploy:dev": "cdk deploy --all --context environment=dev",
    "deploy:prod": "cdk deploy --all --context environment=prod",
    "destroy": "cdk destroy --all",
    "diff": "cdk diff",
    "synth": "cdk synth",
    "bootstrap": "cdk bootstrap"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "aws-cdk": "^2.147.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.600.0",
    "@aws-sdk/client-rekognition": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "aws-cdk-lib": "^2.147.0",
    "aws-lambda": "^1.0.7",
    "aws-xray-sdk-core": "^3.9.0",
    "constructs": "^10.3.0"
  },
  "keywords": [
    "aws",
